# KB Bot – Ollama (low memory defaults)
LLM_MODEL=tinyllama
OLLAMA_NUM_CTX=1024
OLLAMA_BASE_URL=http://localhost:11434

# Alternatives if you have more RAM (edit LLM_MODEL and run: ollama pull <model>)
# LLM_MODEL=gemma2:2b
# LLM_MODEL=phi3:mini

# ── Stage 2 / Real-time search (optional paid fallbacks) ──────────────────────
# DuckDuckGo is used by default (free, no key needed).
# If DDG is blocked or returns no results, the system falls back to these:

# Google Custom Search (https://programmablesearchengine.google.com/)
# GOOGLE_API_KEY=your_google_api_key_here
# GOOGLE_CSE_ID=your_custom_search_engine_id_here

# Bing Search API (https://portal.azure.com → Bing Search v7)
# BING_API_KEY=your_bing_api_key_here
